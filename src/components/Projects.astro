const leftColumn = projects.filter((_, i) => i % 2 === 0)
const rightColumn = projects.filter((_, i) => i % 2 === 1)
---

<section class="bg-paper-white px-4 md:px-12 lg:px-35 py-12">
  <!-- Mobile: single column -->
  <div class="flex flex-col gap-8 md:hidden">
    {
      projects.map((project) => (
        <ProjectCard
          image={project.image}
          category={project.category}
          client={project.client}
          title={project.title}
        />
      ))
    }
  </div>

  <!-- Desktop: 2-column staggered layout with parallax -->
  <div class="hidden md:grid md:grid-cols-2" id="projects-grid">
    <div class="flex flex-col">
      {
        leftColumn.map((project) => (
          <ProjectCard
            image={project.image}
            category={project.category}
            client={project.client}
            title={project.title}
            align={project.align}
            mt={project.mt}
            class="parallax-card"
            data-speed={project.speed}
          />
        ))
      }
    </div>
    <div class="flex flex-col">
      {
        rightColumn.map((project) => (
          <ProjectCard
            image={project.image}
            category={project.category}
            client={project.client}
            title={project.title}
            align={project.align}
            mt={project.mt}
            class="parallax-card"
            data-speed={project.speed}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  const parallaxCards = document.querySelectorAll('.parallax-card')

  if (parallaxCards.length > 0) {
    let rafId: number | null = null
    let mouseX = window.innerWidth / 2
    let mouseY = window.innerHeight / 2

    const updateParallax = () => {
      const windowWidth = window.innerWidth
      const windowHeight = window.innerHeight

      parallaxCards.forEach((card) => {
        const cardEl = card as HTMLElement
        const rect = cardEl.getBoundingClientRect()
        const speed = parseFloat(cardEl.getAttribute('data-speed') || '0.03')

        // Check if card is in viewport (with some buffer)
        const isInView = rect.top < windowHeight + 200 && rect.bottom > -200

        if (isInView) {
          // Calculate scroll parallax
          const viewportProgress =
            (windowHeight - rect.top) / (windowHeight + rect.height)
          const parallaxOffset = viewportProgress * rect.height * speed * 2

          // Calculate cursor magnetic effect
          const cardCenterX = rect.left + rect.width / 2
          const cardCenterY = rect.top + rect.height / 2
          const deltaX = (mouseX - cardCenterX) / windowWidth
          const deltaY = (mouseY - cardCenterY) / windowHeight

          // Subtle non-linear scaling: farther items are pulled slightly stronger
          const magneticX = deltaX * (1 + Math.abs(deltaX)) * 10
          const magneticY = deltaY * (1 + Math.abs(deltaY)) * 25

          // Combine transforms
          cardEl.style.transform = `translateY(${-parallaxOffset}px) translate(${-magneticX}px, ${-magneticY}px)`
        }
      })

      rafId = null
    }

    const onScroll = () => {
      if (rafId === null) {
        rafId = requestAnimationFrame(updateParallax)
      }
    }

    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX
      mouseY = e.clientY
      if (rafId === null) {
        rafId = requestAnimationFrame(updateParallax)
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('mousemove', onMouseMove, { passive: true })
    updateParallax()
  }
</script>
