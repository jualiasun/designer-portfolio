---
import { Image } from 'astro:assets'
import crane from '../assets/intro/crane.png'
import avatar from '../assets/intro/avatar.png'
import clsx from 'clsx'
---

<section
  class={clsx(
    'bg-deep-black relative overflow-hidden text-deep-black',
    'min-h-screen pt-[calc(var(--header-height)+24px)] flex flex-col justify-end',
  )}
>
  <Image
    src={crane}
    alt=""
    class="absolute top-[calc(var(--header-height)+24px)] w-[110%] max-w-none left-1/2 -translate-x-1/2"
  />
  <div
    class={clsx(
      'bg-[url("/images/paper-bg.png")] bg-position-[bottom_-45px_center] bg-no-repeat bg-size-[auto_110%]',
      'flex flex-col justify-end px-4 gap-y-8 py-13',
      'relative z-10',
    )}
  >
    <Image src={avatar} alt="" class="w-25 rotate-2 self-end mr-6" />
    <div class="flex flex-col gap-y-8">
      <div class="flex flex-col gap-y-5">
        <h3 class="font-bold text-lg">Shaping Things That Matter</h3>
        <p class="text-sm">
          I'm not into safe design. I focus on strong concepts, visual impact,
          and work that stands out for the right reasons. I mix illustration,
          typography, and bold compositions to shape ideas, with experience
          across SaaS and tech where clarity still matters.
        </p>
      </div>
      <h1 class="text-[60px] font-boldonse uppercase">My work</h1>
    </div>
  </div>
</section>
