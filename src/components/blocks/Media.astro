---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import clsx from 'clsx'

type FileItem = ImageMetadata | string

type Padding = 'none' | 'default' | { inline?: string; block?: string }

interface Props {
  files: FileItem[]
  padding?: Padding
  aspect?: string
  overlayImage?: ImageMetadata
}

const { files, padding = 'none', aspect, overlayImage } = Astro.props

const isCustomPadding = typeof padding === 'object'
const isPadded = padding === 'default' || isCustomPadding

const containerClass = clsx(
  'relative flex flex-col',
  isPadded && 'gap-x-10 md:flex-row',
  padding === 'default' && 'md:p-15',
  isCustomPadding &&
    'md:px-[var(--media-padding-inline)] md:py-[var(--media-padding-block)]',
)

const containerStyle = isCustomPadding
  ? `--media-padding-inline: ${padding.inline ?? '0'}; --media-padding-block: ${padding.block ?? '0'};`
  : undefined

const imageClass = isPadded ? 'flex-1 min-w-0' : ''
const videoClass = isPadded ? 'flex-1 min-w-0' : 'w-full'
---

<section class={containerClass} style={containerStyle}>
  {
    files.map((file) =>
      typeof file === 'string' ? (
        aspect ? (
          <div
            class={clsx(
              'overflow-hidden',
              isPadded ? 'flex-1 min-w-0' : 'w-full',
            )}
            style={`aspect-ratio: ${aspect}`}
          >
            <video
              src={file}
              autoplay
              loop
              muted
              playsinline
              class="size-full object-cover"
            />
          </div>
        ) : (
          <video
            src={file}
            autoplay
            loop
            muted
            playsinline
            class={videoClass}
          />
        )
      ) : (
        <Image src={file} alt="" class={imageClass} />
      ),
    )
  }
  {
    overlayImage && (
      <Image
        src={overlayImage}
        alt=""
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[180px] md:w-100"
      />
    )
  }
</section>
