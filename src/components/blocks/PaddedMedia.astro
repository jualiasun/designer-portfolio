---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

type FileItem = ImageMetadata | string

interface Props {
  files: FileItem[]
  overlayImage?: ImageMetadata
}

const { files, overlayImage } = Astro.props
---

<section class="flex gap-x-10 flex-col md:flex-row md:p-15 relative">
  {
    files.map((file) =>
      typeof file === 'string' ? (
        <video
          src={file}
          autoplay
          muted
          playsinline
          loop
          class="flex-1 min-w-0"
        />
      ) : (
        <Image src={file} alt="" class="flex-1 min-w-0" />
      ),
    )
  }
  {
    overlayImage && (
      <Image
        src={overlayImage}
        alt=""
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[180px] md:w-100"
      />
    )
  }
</section>
