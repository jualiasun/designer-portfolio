---
import { Image } from 'astro:assets'
import clsx from 'clsx'

type Align = 'left' | 'right' | 'indented-left' | 'indented-right'

interface Props {
  image: ImageMetadata
  category: string
  client: string
  title: string
  id: string
  align?: Align
  mt?: string
  class?: string
  'data-speed'?: number
}

const {
  image,
  category,
  client,
  title,
  id,
  align = 'left',
  mt = '',
  class: className = '',
  'data-speed': dataSpeed,
  ...rest
} = Astro.props

const alignClasses: Record<Align, string> = {
  left: 'md:self-start',
  right: 'md:self-end',
  'indented-left': 'md:self-end md:mr-1.5',
  'indented-right': 'md:self-start md:ml-1.5',
}
---

<a
  href={`/${id}`}
  class={clsx(
    'bg-white flex flex-col gap-4 lg:gap-5 overflow-hidden md:w-64 lg:w-90 xl:w-125 aspect-5/6',
    alignClasses[align],
    mt,
    className,
  )}
  data-speed={dataSpeed}
  {...rest}
>
  <Image src={image} alt="" class="aspect-5/4 h-auto object-cover" />
  <div
    class="grow flex flex-col justify-between text-deep-black px-4 xl:px-5 pb-4 xl:pb-5 capitalize"
  >
    <div
      class="flex items-center justify-between w-full text-[3vw] md:text-[10px] lg:text-base xl:text-lg capitalize whitespace-nowrap"
    >
      <p>{category}</p>
      <p class="text-right">{client}</p>
    </div>
    <p
      class="text-[6vw] md:text-base lg:text-2xl xl:text-3xl font-medium leading-snug whitespace-pre-line"
    >
      {title}
    </p>
  </div>
</a>
