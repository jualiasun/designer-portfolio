---
import { Image } from 'astro:assets'

interface Props {
  image: ImageMetadata
  category: string
  client: string
  title: string
}

const { image, category, client, title } = Astro.props
---

<div class="bg-white flex flex-col gap-5 overflow-hidden">
  <Image src={image} alt="" class="h-72 w-full object-cover" />
  <div class="flex flex-col gap-8 text-deep-black px-4 pb-6">
    <div
      class="flex items-center justify-between w-full text-sm capitalize whitespace-nowrap"
    >
      <p>{category}</p>
      <p class="text-right">{client}</p>
    </div>
    <p class="text-2xl font-medium leading-snug">
      {title}
    </p>
  </div>
</div>
