---
import { Image } from 'astro:assets'
import clsx from 'clsx'

type Align = 'left' | 'right' | 'indented-left' | 'indented-right'

interface Props {
  image: ImageMetadata
  category: string
  client: string
  title: string
  align?: Align
  mt?: string
}

const { image, category, client, title, align = 'left', mt = '' } = Astro.props

const alignClasses: Record<Align, string> = {
  left: 'md:self-start',
  right: 'md:self-end',
  'indented-left': 'md:self-end',
  'indented-right': 'md:self-start',
}
---

<div
  class={clsx(
    'bg-white flex flex-col gap-5 overflow-hidden',
    'md:w-[80%]',
    alignClasses[align],
    mt,
  )}
>
  <Image
    src={image}
    alt=""
    class="h-72 sm:h-52 lg:h-72 2xl:h-100 w-full object-cover"
  />
  <div
    class="flex flex-col gap-8 sm:gap-6 lg:gap-8 xl:gap-12 text-deep-black px-4 xl:px-5 pb-6"
  >
    <div
      class="flex items-center justify-between w-full text-sm lg:text-base xl:text-lg capitalize whitespace-nowrap"
    >
      <p>{category}</p>
      <p class="text-right">{client}</p>
    </div>
    <p
      class="text-2xl sm:text-base lg:text-2xl xl:text-3xl font-medium leading-snug"
    >
      {title}
    </p>
  </div>
</div>
