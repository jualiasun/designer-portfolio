---
import { Image } from 'astro:assets'
import type { HTMLAttributes } from 'astro/types'

type Align = 'left' | 'right' | 'indented-left' | 'indented-right'

interface Props extends Omit<HTMLAttributes<'a'>, 'class'> {
  image: ImageMetadata
  category: string
  client: string
  title: string
  id: string
  align?: Align
  mt?: string
  class?: string
  scaleText?: boolean
  'data-speed'?: number
}

const {
  image,
  category,
  client,
  title,
  id,
  align = 'left',
  mt = '',
  class: className = '',
  scaleText = false,
  'data-speed': dataSpeed,
  ...rest
} = Astro.props

const metaTextClasses = scaleText
  ? 'text-[3vw] md:text-[10px] lg:text-base xl:text-lg'
  : 'text-xs md:text-[10px] lg:text-base xl:text-lg'

const titleTextClasses = scaleText
  ? 'text-[6vw] md:text-base lg:text-2xl xl:text-3xl'
  : 'text-xl md:text-base lg:text-2xl xl:text-3xl'

const alignClasses: Record<Align, string> = {
  left: 'md:self-start',
  right: 'md:self-end',
  'indented-left': 'md:self-end md:mr-1.5',
  'indented-right': 'md:self-start md:ml-1.5',
}
---

<a
  id={`project-card-${id}`}
  href={`/${id}`}
  class:list={[
    'bg-white flex flex-col gap-4 lg:gap-5 overflow-hidden w-90 md:w-64 lg:w-90 xl:w-125 aspect-5/6 transition-transform duration-300 ease-out hover:scale-[1.03]',
    alignClasses[align],
    mt,
    className,
  ]}
  data-speed={dataSpeed}
  data-project-id={id}
  data-project-title={title}
  data-project-client={client}
  data-project-category={category}
  {...rest}
>
  <Image src={image} alt="" class="aspect-5/4 h-auto object-cover" />
  <div
    class="grow flex flex-col justify-between text-deep-black px-4 xl:px-5 pb-4 xl:pb-5 capitalize"
  >
    <div
      class:list={[
        'flex items-center justify-between w-full capitalize whitespace-nowrap',
        metaTextClasses,
      ]}
    >
      <p>{category}</p>
      <p class="text-right">{client}</p>
    </div>
    <p
      class:list={[
        'font-medium leading-snug whitespace-pre-line',
        titleTextClasses,
      ]}
    >
      {title}
    </p>
  </div>
</a>

<script is:inline define:vars={{ cardId: `project-card-${id}`, projectId: id, projectTitle: title, projectClient: client, projectCategory: category }}>
  var card = document.getElementById(cardId)
  if (card) {
    card.addEventListener('click', function() {
      window.posthog?.capture('project_card_clicked', {
        project_id: projectId,
        project_title: projectTitle,
        project_client: projectClient,
        project_category: projectCategory,
      })
    })
  }
</script>
