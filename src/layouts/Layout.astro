---
import '../styles/global.css'
import { Font } from 'astro:assets'
import Header from '../components/Header.astro'
import Footer from '../components/footer/Footer.astro'

interface Props {
  title: string
  withTopPadding?: boolean
}

const { title, withTopPadding = false } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-boldonse" />
    <Font cssVariable="--font-aktiv-grotesk" />
    <title>{title}</title>
  </head>
  <body class="font-aktiv-grotesk bg-deep-black">
    <div>
      <Header />
      <main
        class:list={[
          'mt-[calc(-1*var(--header-height))]',
          withTopPadding && [
            'max-md:pt-30',
            'max-md:before:absolute max-md:before:z-10',
            'max-md:before:top-0 max-md:before:left-0',
            'max-md:before:w-full max-md:before:h-53',
            'max-md:before:bg-[url(/images/intro/header-paper.png)]',
            'max-md:before:bg-bottom max-md:before:bg-no-repeat',
          ],
        ]}
      >
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
